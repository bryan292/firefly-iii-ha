#!/usr/bin/with-contenv bashio
# ==============================================================================
# Home Assistant Add-on: Firefly III
# Runs the Nginx daemon
# ==============================================================================

# Wait until PHP-FPM is available
bashio::net.wait_for 9000 localhost 300

# Ensure proper permissions for temp directories
chmod -R 777 /tmp/nginx || true
chmod -R 777 /var/lib/nginx || true
chmod -R 777 /var/www || true

# Start Nginx
bashio::log.info "Starting Nginx..."
exec nginx -g "daemon off;"
