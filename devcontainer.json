{
    "name": "Firefly III Add-on Development",
    "dockerComposeFile": "docker-compose.dev.yml",
    "service": "firefly",
    "workspaceFolder": "/workspace",
    "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
    },
    "extensions": [
        "timonwong.shellcheck",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
    ],
    "forwardPorts": [8080],
    "postCreateCommand": "apt-get update && apt-get install -y shellcheck",
    "remoteUser": "root"
}
